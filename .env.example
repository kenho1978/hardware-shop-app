# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/hardware_shop

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Stripe (for credit card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayMe by HSBC
PAYME_CLIENT_ID=your_payme_client_id
PAYME_CLIENT_SECRET=your_payme_client_secret
PAYME_REDIRECT_URI=http://localhost:4000/api/payments/payme/callback

# FPS (Faster Payment System)
FPS_MERCHANT_ID=your_fps_merchant_id
FPS_API_KEY=your_fps_api_key

# Octopus
OCTOPUS_MERCHANT_ID=your_octopus_merchant_id
OCTOPUS_API_KEY=your_octopus_api_key

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000